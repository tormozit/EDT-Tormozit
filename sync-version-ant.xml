<?xml version="1.0" encoding="UTF-8"?>
<project name="Sync version" default="sync">
	<property name="site.dir" location="${basedir}/tormozit.edt.site"/>

	<target name="sync">
		<delete dir="${site.dir}/plugins" failonerror="false" quiet="true"/>
		<delete dir="${site.dir}/features" failonerror="false" quiet="true"/>
		<delete file="${site.dir}/content.jar" failonerror="false" quiet="true"/>
		<delete file="${site.dir}/artifacts.jar" failonerror="false" quiet="true"/>
		<delete failonerror="false" quiet="true">
			<fileset dir="${site.dir}" includes="*.zip"/>
		</delete>

		<exec executable="cmd.exe" failonerror="true">
			<arg value="/c"/>
			<arg path="${basedir}/sync-version.bat"/>
		</exec>

		<eclipse.refreshLocal resource="/tormozit.edt" depth="infinite"/>
		<eclipse.refreshLocal resource="/tormozit.edt.feature" depth="infinite"/>
		<eclipse.refreshLocal resource="/tormozit.edt.site" depth="infinite"/>

		<eclipse.incrementalBuild project="tormozit.edt" kind="full"/>
		<eclipse.incrementalBuild project="tormozit.edt.feature" kind="full"/>
	</target>
</project>
